npx lint-staged

# Reject warning suppressions in staged files
SUPPRESSION_PATTERNS='ignoreCodes|@ts-ignore|@ts-expect-error|eslint-disable|eslint-disable-next-line|noinspection|\|\| true'
if git diff --cached --diff-filter=ACMR -U0 -- '*.ts' '*.mjs' '*.json' | grep -P "^\+" | grep -vP "^\+\+\+" | grep -qP "$SUPPRESSION_PATTERNS"; then
  echo "ERROR: Staged changes contain warning/error suppressions."
  echo "Matches:"
  git diff --cached --diff-filter=ACMR -U0 -- '*.ts' '*.mjs' '*.json' | grep -P "^\+" | grep -vP "^\+\+\+" | grep -P "$SUPPRESSION_PATTERNS"
  echo ""
  echo "Fix the underlying issue instead of suppressing it."
  exit 1
fi

# Roam quality gates
# Note: roam health --gate uses a hardcoded threshold of 60 which is unreachable
# due to roam v11.2.0 counting interface properties as isolated symbols (they have
# no import edges). Using a manual threshold until this is fixed upstream.
# See: algebraic connectivity = 0.0 caused by ~100 sub-symbols with zero edges.
ROAM_HEALTH_MIN=25
if command -v roam &> /dev/null; then
  roam index
  SCORE=$(roam --json health 2>/dev/null | python3 -c "import json,sys; print(json.load(sys.stdin).get('health_score',0))" 2>/dev/null || echo 0)
  echo "Health score: $SCORE (threshold: $ROAM_HEALTH_MIN)"
  if [ "$SCORE" -lt "$ROAM_HEALTH_MIN" ]; then
    echo "ERROR: Health score $SCORE is below minimum $ROAM_HEALTH_MIN"
    exit 1
  fi
  roam diff
fi
