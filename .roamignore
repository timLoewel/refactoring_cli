# Test fixtures — standalone programs, not part of the dependency graph.
**/*.fixture.ts
**/fixtures/**
src/testing/__fixtures__/**

# Test files — not production architecture
**/*.test.ts
src/testing/**

# Config files — no meaningful dependency edges
jest.config.ts

# Temporary/scratch files
tmp/**

# Scripts — standalone tooling
scripts/**

# Non-TypeScript directories — not part of the dependency graph
openspec/**
.opencode/**
.claude/**
.github/**
